# 复制为 .env.local 后填写（勿提交真实密钥）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 可选，自建兼容网关时填写，默认 https://api.openai.com/v1
# OPENAI_BASE_URL=

# 构建时可选：静态资源 CDN 根（不要末尾 /）
# ASSET_PREFIX=https://static.example.com/sz-policy

# 应用路由与 _next 静态资源前缀：
# - 生产构建（npm run build）未设置时默认为 /gov（与 Nginx 子路径一致）
# - 本地开发（npm run dev）不带前缀，访问 http://localhost:3000/
# 生产若整站部署在域名根，构建前设置：NEXT_BASE_PATH=/
# NEXT_BASE_PATH=/
