# 复制为 .env.local 后填写（勿提交真实密钥）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 可选，自建兼容网关时填写，默认 https://api.openai.com/v1
# OPENAI_BASE_URL=

# 构建时可选：静态资源 CDN 根（不要末尾 /）。若同时设 NEXT_BASE_PATH，勿让 ASSET_PREFIX 以同一路径结尾（避免叠层）
# ASSET_PREFIX=https://static.example.com

# 可选：Next basePath（如 /gov），不设则资源为 /_next/...，适合「页面在 /gov/、静态在 /」的 Nginx 剥前缀方案
# NEXT_BASE_PATH=/gov
