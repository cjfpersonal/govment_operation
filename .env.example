# 复制为 .env.local 后填写（勿提交真实密钥）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 可选，自建兼容网关时填写，默认 https://api.openai.com/v1
# OPENAI_BASE_URL=

# 构建时可选，默认不写：与站点同源，引用 `/_next/static`（相对站点根）
# 仅当 JS/CSS 要从另一完整 URL 根加载时再设（不要末尾 /），须与实际上线地址一致
# ASSET_PREFIX=https://static.example.com/sz-policy

# 构建时可选：站点子路径（与 Nginx location 一致），例 /gov；不设则部署在域名根
# NEXT_BASE_PATH=/gov
